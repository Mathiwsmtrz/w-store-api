PORT=80
# Preferred: full PostgreSQL URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_back

# Optional fallback (used only if DATABASE_URL/DB_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=store_back
DB_SYNCHRONIZE=false

# Wompi integration
# See /Users/mathiws/Projects/wompi/WOMPI_ENVIRONMENTS.md for valid key+URL combinations.
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_ENV=sandbox
WOMPI_CURRENCY=COP
WOMPI_API_BASE_URL=
